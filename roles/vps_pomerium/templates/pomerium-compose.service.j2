[Unit]
Description=Edge Pomerium Docker Compose stack
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory={{ pomerium_base_dir }}
ExecStart=/usr/bin/docker compose -f {{ pomerium_compose_path }} up -d --remove-orphans
ExecStop=/usr/bin/docker compose -f {{ pomerium_compose_path }} stop
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target
