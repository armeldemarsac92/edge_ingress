# Ansible managed: VPS public edge firewall.
table inet vps_edge_firewall {
    set admin_ssh_sources {
        type ipv4_addr;
        flags interval;
        elements = { {{ edge_admin_ssh_sources | join(', ') }} };
    }

    set public_tcp_ports {
        type inet_service;
        elements = {
            80,
            443{% for forward in edge_tcp_forwards | default([]) %},
            {{ forward.public_port }}{% endfor %}{% for port in edge_firewall_public_tcp_ports_extra %},
            {{ port }}{% endfor %}
        };
    }

    set wireguard_udp_ports {
        type inet_service;
        elements = {
{% for item in wireguard_links | dict2items %}
            {{ item.value.vps_listen_port }}{% if not loop.last %},{% endif %}
{% endfor %}
        };
    }
{% if edge_firewall_wireguard_sources | length > 0 %}

    set wireguard_udp_sources {
        type ipv4_addr;
        flags interval;
        elements = { {{ edge_firewall_wireguard_sources | join(', ') }} };
    }
{% endif %}
{% if edge_firewall_wireguard_tcp_sources | length > 0 and edge_firewall_wireguard_tcp_ports_extra | length > 0 %}

    set wireguard_tcp_sources {
        type ipv4_addr;
        flags interval;
        elements = { {{ edge_firewall_wireguard_tcp_sources | join(', ') }} };
    }

    set wireguard_tcp_ports {
        type inet_service;
        elements = { {{ edge_firewall_wireguard_tcp_ports_extra | join(', ') }} };
    }
{% endif %}

    chain input {
        type filter hook input priority filter; policy drop;
        ct state established,related accept
        iifname "lo" accept
{% if edge_firewall_allow_icmp | bool %}
        ip protocol icmp accept
{% endif %}
        tcp dport {{ edge_firewall_ssh_port }} ip saddr @admin_ssh_sources accept
{% if edge_firewall_wireguard_sources | length > 0 %}
        udp dport @wireguard_udp_ports ip saddr @wireguard_udp_sources accept
{% else %}
        udp dport @wireguard_udp_ports accept
{% endif %}
{% if edge_firewall_wireguard_tcp_sources | length > 0 and edge_firewall_wireguard_tcp_ports_extra | length > 0 %}
        tcp dport @wireguard_tcp_ports ip saddr @wireguard_tcp_sources accept
{% endif %}
        tcp dport @public_tcp_ports accept
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
        ct state established,related accept
{% for item in wireguard_links | dict2items %}
        iifname "{{ item.value.vps_if }}" ip daddr {{ provider_cidr }} accept
{% endfor %}
    }
}
