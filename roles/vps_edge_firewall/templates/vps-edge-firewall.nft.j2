# Ansible managed: VPS public edge firewall.
table inet vps_edge_firewall {
    set admin_ssh_sources {
        type ipv4_addr;
        flags interval;
        elements = { {{ edge_admin_ssh_sources | join(', ') }} };
    }

    set public_tcp_ports {
        type inet_service;
        elements = {
            80,
            443{% if edge_minecraft_enabled | bool %},
            25565{% endif %}{% for forward in edge_tcp_forwards | default([]) %},
            {{ forward.public_port }}{% endfor %}{% for port in edge_firewall_public_tcp_ports_extra %},
            {{ port }}{% endfor %}
        };
    }

    set wireguard_udp_ports {
        type inet_service;
        elements = {
{% for item in wireguard_links | dict2items %}
            {{ item.value.vps_listen_port }}{% if not loop.last %},{% endif %}
{% endfor %}
        };
    }

    chain input {
        type filter hook input priority filter; policy drop;
        ct state established,related accept
        iifname "lo" accept
{% if edge_firewall_allow_icmp | bool %}
        ip protocol icmp accept
{% endif %}
        tcp dport {{ edge_firewall_ssh_port }} ip saddr @admin_ssh_sources accept
        udp dport @wireguard_udp_ports accept
        tcp dport @public_tcp_ports accept
    }

    chain forward {
        type filter hook forward priority filter; policy drop;
        ct state established,related accept
{% for item in wireguard_links | dict2items %}
        iifname "{{ item.value.vps_if }}" ip daddr {{ provider_cidr }} accept
{% endfor %}
    }
}
